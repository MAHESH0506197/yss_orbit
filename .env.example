// yss_orbit\.env.example
# =====================================================================
# YSS ORBIT — .env.example
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# =====================================================================

# ============================
# DJANGO CORE
# ============================
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=your-super-secret-key-min-50-chars-change-this-now
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ============================
# JWT
# ============================
JWT_SIGNING_KEY=your-jwt-signing-key-must-be-at-least-32-characters-long
JWT_REFRESH_SIGNING_KEY=your-jwt-refresh-signing-key-at-least-32-characters

# ============================
# DATABASE
# ============================
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/YSS_ORBIT_DB
DATABASE_REPLICA_URL=postgres://postgres:yourpassword@localhost:5432/YSS_ORBIT_DB

# ============================
# REDIS
# ============================
REDIS_URL=redis://localhost:6379

# ============================
# ENCRYPTION
# ============================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-encryption-key-here

# ============================
# CORS
# ============================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================
# EMAIL
# ============================
DEFAULT_FROM_EMAIL=noreply@yssorbit.com
SERVER_EMAIL=server@yssorbit.com
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# ============================
# SENTRY
# ============================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================
# OPENTELEMETRY
# ============================
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=yss-orbit-api

# ============================
# PLATFORM
# ============================
PLATFORM_SUPPORT_EMAIL=support@yssorbit.com

# ============================
# RAZORPAY
# ============================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ============================
# SENDGRID
# ============================
SENDGRID_API_KEY=

# ============================
# TWILIO (SMS)
# ============================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================
# WHATSAPP BUSINESS
# ============================
WABA_TOKEN=

# ============================
# AWS S3
# ============================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_CUSTOM_DOMAIN=

# ============================
# GST API
# ============================
GST_API_URL=https://api.gst.gov.in/
GST_API_KEY=

# ============================
# VIRUS SCANNING
# ============================
VIRUS_SCAN_ENABLED=False

# ============================
# BIOMETRIC
# ============================
BIOMETRIC_POLL_INTERVAL_MINUTES=15
